{
  "crons": [
    {
      "path": "/api/scheduled-sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/weekly-games-email",
      "schedule": "0 13 * * 0"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
