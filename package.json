{
  "name": "referee-dashboard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:api": "tsc --noEmit -p tsconfig.api.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:api",
    "test": "vitest run src",
    "test:e2e": "node scripts/run-playwright-smoke.mjs",
    "qa:smoke": "node scripts/run-playwright-smoke.mjs",
    "qa:release": "npm run typecheck:all && npm test && npm run lint && npm run build && npm run qa:smoke",
    "lint": "eslint .",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "node-ical": "^0.26.1",
    "papaparse": "^5.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.2",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vercel/node": "^5.8.12",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@vercel/static-config": {
      "ajv": "^8.18.0"
    },
    "esbuild": "^0.28.1",
    "minimatch": "^10.2.5",
    "path-to-regexp": "^6.3.0",
    "smol-toml": "^1.6.1",
    "undici": "^6.24.0"
  }
}
