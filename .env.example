VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY

# Server-only Vercel environment variables:
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLIC_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_SECRET_KEY
CRON_SECRET=generate_a_random_32_plus_character_value

# Server-only email configuration:
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
EMAIL_FROM="Whistle Keeper <support@whistlekeeper.com>"
EMAIL_REPLY_TO=support@whistlekeeper.com
SUPPORT_EMAIL=support@whistlekeeper.com
BETA_REQUEST_NOTIFY_TO=owner@example.com
WEEKLY_EMAIL_FROM="Whistle Keeper <support@whistlekeeper.com>"
WEEKLY_EMAIL_REPLY_TO=support@whistlekeeper.com
APP_URL=https://your-app.example.com

# Legacy names still work during rotation, but prefer the variables above:
# VITE_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_LEGACY_SERVICE_ROLE_KEY
